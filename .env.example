# NRI Yield Advisory API - example configuration
# Copy to .env for local development. Do not commit real .env files.

NODE_ENV=development

# Service ports
GATEWAY_PORT=8080
YIELD_ENGINE_PORT=8082
ESB_PORT=8081
AUTH_PORT=8083
AUDIT_PORT=8084
BANK_PORT=8085
FRONTEND_PORT=3000

# Internal service URLs
YIELD_ENGINE_URL=http://localhost:8082
ESB_URL=http://localhost:8081
AUTH_SERVICE_URL=http://localhost:8083
AUDIT_SERVICE_URL=http://localhost:8084
BANK_INTEGRATION_SERVICE_URL=http://localhost:8085
PUBLIC_API_BASE=http://localhost:8080

# Local development secrets only. Production must use high-entropy secret-manager values.
HMAC_SHARED_SECRET=
JWT_SECRET=

# Redis and persistence
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
CBS_CACHE_TTL_SECONDS=120
IDEMPOTENCY_TTL_SECONDS=86400
STORAGE_DRIVER=mysql

# Security
CORS_ORIGINS=http://localhost:3000
TIMESTAMP_SKEW_SECONDS=30
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=10
AUTH_SEED_DEMO_USERS=true
AUTH_DEMO_PASSWORD=

# Market data providers:
# - open-er-api: local/dev free FX feed
# - bank-tms: production bank treasury market-data adapter
FX_FEED_PROVIDER=open-er-api
FX_FEED_BASE_URL=https://open.er-api.com/v6/latest/INR
FX_FEED_API_KEY=
TMS_MARKET_DATA_URL=
FX_FEED_TIMEOUT_MS=8000
RATE_UPDATE_INTERVAL_MS=60000
ALLOW_FREE_FX_FEED_IN_PRODUCTION=false

# Bank portfolio adapter. Required when NODE_ENV=production and BANK_LIVE_MODE=true.
BANK_LIVE_MODE=false
CBS_ADAPTER_URL=
ALLOW_MOCK_BANK_IN_PRODUCTION=false

# Production database settings when STORAGE_DRIVER=mysql.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=nri_yield
MYSQL_CONNECTION_LIMIT=20

LOG_LEVEL=debug
LOG_FILE=true
AUDIT_RETENTION_DAYS=90
METRICS_ENABLED=true
